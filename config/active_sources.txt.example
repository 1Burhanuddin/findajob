# config/active_sources.txt — registered job-source adapters active for
# this stack. One adapter name per line. Comments and blank lines OK.
# Default if file missing: ["jobs-api14"] (preserves pre-v0.14 behavior).
#
# Adapter names match registry identifiers in
# src/findajob/fetchers/adapters/registry.py — currently:
#   - jobs-api14         # Jobs API (RapidAPI)
#   - jobs-api14-indeed  # Jobs API Indeed endpoint (RapidAPI; shares JOBS_API14_KEY)
#   - jobs-api14-bing    # Jobs API Bing endpoint (RapidAPI; shares JOBS_API14_KEY) — opt-in
#   - jsearch            # JSearch (RapidAPI)
#   - greenhouse         # Greenhouse boards (public API; needs feed_urls.txt slugs)
#   - ashby              # Ashby boards (public API; needs feed_urls.txt slugs)
#   - lever              # Lever boards (public API; needs feed_urls.txt slugs)
#   - gmail              # Gmail job-alert digests (IMAP; needs config/gmail.json)

jobs-api14
greenhouse
ashby
lever
gmail
# jobs-api14-bing  # Uncomment to enable Bing endpoint (#422; opt-in until first triage-day measurement decides title-allowlist tuning)
