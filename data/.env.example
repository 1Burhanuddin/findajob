# data/.env — API keys and secrets
# Copy to data/.env and fill in your values.
# chmod 600 data/.env
# This file is gitignored. Never commit your actual .env.

# ── LLM APIs ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here       # Used for DeepSeek v3 job scoring
GOOGLE_API_KEY=your_key_here           # Gemini (default model + embeddings)
PERPLEXITY_API_KEY=your_key_here       # Company research (sonar-pro)
GROQ_API_KEY=your_key_here             # Optional
XAI_API_KEY=your_key_here              # Optional

# ── Job Data APIs ─────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_key_here             # jobs-api14 (LinkedIn + Indeed search)

# ── Notifications ─────────────────────────────────────────────────────────────
NTFY_TOPIC=your-ntfy-topic             # Create a topic at ntfy.sh (or self-host)

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Service account credentials go in config/gsheets_creds.json (gitignored)
# Sheet ID goes in config/sheet_id.txt (gitignored)
