# data/.env — API keys and secrets
# Copy to data/.env and fill in your values.
# Under a Docker deploy this file lives at state/data/.env and is
# bind-mounted to /app/data/.env inside the container.
# chmod 600 data/.env
# This file is gitignored. Never commit your actual .env.

# ── LLM APIs ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_key_here       # All chat calls — every pipeline role (Opus 4.7, Sonnet 4.6, Gemini 3 Flash, DeepSeek v3, Sonar)

# ── Job Data APIs ─────────────────────────────────────────────────────────────
# RapidAPI account-level key. ONE key authorizes every API you've subscribed
# to under your RapidAPI account (jobs-api14 LinkedIn / Indeed / Bing,
# JSearch, etc). New stacks set only this; legacy stacks may still set the
# per-adapter vars below as fallback (#414).
RAPIDAPI_KEY=

# Legacy per-adapter env vars (#408). Still read as fallback when
# RAPIDAPI_KEY is unset. Don't set these unless you genuinely have separate
# RapidAPI accounts for different APIs (rare).
# JOBS_API14_KEY=
# JSEARCH_API_KEY=

# Optional: per-stack pagination ceiling for JobsApi14Adapter (LinkedIn
# endpoint). Default 1 = single-page (10 jobs/query). Each additional page
# costs 1 RapidAPI request (per-call billing — empirically confirmed).
# PRO-tier (jobs-api14 = 20,000/month) operators can safely raise to 3–5;
# free-tier operators should leave at 1. Clamped to [1, 20]. (#414 PR2)
# JOBS_API14_MAX_PAGES=1

# Optional: per-stack pagination width for JSearchAdapter. Default 1 =
# server returns ~10 jobs/query. JSearch handles pagination server-side
# (one HTTP request per query), but bills each page as one RapidAPI
# request. PRO-tier (JSearch = 10,000/month) operators can safely raise
# to 3 (~27 jobs/query, ~2.7x yield). Clamped to [1, 10]. (#414 PR3)
# JSEARCH_NUM_PAGES=1

# ── Notifications ─────────────────────────────────────────────────────────────
NTFY_TOPIC=your-ntfy-topic             # Create a topic at ntfy.sh (or self-host)

# Optional: cost-threshold for the weekly company_discoverer ntfy. Fires a
# "discovery: cost exceeded threshold" alert when a single discovery run's
# OpenRouter cost (response.usage.cost) exceeds this dollar amount. Default
# $1.00; empirical runs land around $0.10. Raise if the alert is too noisy;
# lower for tighter cost-anomaly signal. (#287, #462)
# DISCOVERY_COST_THRESHOLD_USD=1.00

# ── Optional: HTTP Basic Auth for internet-exposed instances (#327) ──────────
# Set both to gate the findajob web UI behind HTTP Basic Auth. Intended for
# per-tester instances reachable on the public internet. When either is unset
# (or empty), no authentication is enforced — fine for VPN-only or
# loopback deployments. See docs/getting-started/internet-exposure.md.
FINDAJOB_AUTH_USER=                    # leave empty to disable auth
FINDAJOB_AUTH_PASS=                    # leave empty to disable auth
