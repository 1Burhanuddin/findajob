# ops/fly.toml.example — Fly.io deployment template for one findajob tenant.
#
# Usage:
#   1. cp ops/fly.toml.example ops/fly.toml
#   2. Edit `app` below to your chosen Fly app name (one app per tenant,
#      e.g. findajob-<handle>). The rest of this file can stay as-is for
#      a first deploy.
#   3. bash ops/fly-deploy.sh
#
# Full runbook: docs/operations/fly-deploy.md
#
# This .example is tracked; the real ops/fly.toml is gitignored because it
# carries the chosen Fly app name (operator topology). The image is public
# on GHCR so no registry auth is needed.

app = "REPLACE_WITH_FLY_APP_NAME"
primary_region = "iad"

# Pinned image tag. The image runs unchanged from the compose stack —
# supercronic stays PID 1, uvicorn is a child process. Bump this string
# when rolling to a new release and re-run ops/fly-deploy.sh (or just
# `fly deploy --config ops/fly.toml`).
[build]
  image = "ghcr.io/brockamer/findajob:v0.27.4"

# Non-secret env. Mirrors compose.yaml.example's environment block, with
# one critical difference: JSP_BASE points at /app/state, not /app. Fly
# machines support exactly one volume per machine, so the six state subdirs
# (data/, logs/, companies/, config/, candidate_context/, .backups/) live
# under a single volume root. The entrypoint materializes them on first boot.
# Secrets (OPENROUTER_API_KEY, RAPIDAPI_KEY, NTFY_TOPIC, FINDAJOB_AUTH_USER,
# FINDAJOB_AUTH_PASS, FINDAJOB_WEB_URL) are set via `fly secrets set` —
# the deploy script prompts for any that are missing.
[env]
  JSP_BASE = "/app/state"
  PUID = "1000"
  PGID = "1000"
  TZ = "America/New_York"

# Public HTTP service. The basic-auth gate lives inside the FastAPI app
# (findajob.web.auth.BasicAuthMiddleware), gated on the AUTH_USER/PASS
# secrets — same code path as the compose stack. /healthz is allowlisted
# upstream of the gate so the platform's health check can probe it
# anonymously.
[http_service]
  internal_port = 8090
  force_https = true
  auto_stop_machines = "off"
  auto_start_machines = true
  min_machines_running = 1

  [[http_service.checks]]
    type = "http"
    method = "GET"
    path = "/healthz"
    interval = "30s"
    timeout = "5s"
    grace_period = "60s"

[[vm]]
  size = "shared-cpu-1x"
  memory = "1gb"

# One volume, sized for all six state subdirs combined. POSIX block device
# (ext4), so SQLite at $JSP_BASE/data/pipeline.db works the same as on the
# host. The entrypoint mkdir -p's the subdirs on first boot. 8 GB is the
# starting point (sum of the six compose-side defaults: 1+1+3+1+1+1); extend
# later with `fly volumes extend <id>` if companies/ grows.
[[mounts]]
  source = "findajob_state"
  destination = "/app/state"
  initial_size = "8gb"
