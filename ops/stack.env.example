# ops/stack.env.example
# Copy to your stack dir as .env (Dockge auto-loads it).
# This file is per-instance and intentionally NOT secret — commit to
# your own config store if you want, but don't put API keys here.
# API keys go in state/data/.env (chmod 600).

# Image tag to pull. Every stack tracks `:latest`; pin to a specific
# `vX.Y.Z` immutable tag only if you intentionally want to freeze a stack
# on a known image. `main-<sha>` is also available for precise commit-level
# pinning.
FINDAJOB_IMAGE_TAG=latest

# Container timezone (sets cron schedule evaluation)
# Examples: America/Los_Angeles, America/New_York, Europe/London
FINDAJOB_TZ=America/New_York

# Host UID/GID to run the container as. Must match the owner of ./state/
# so bind-mounted files are host-editable through Dockge's file viewer.
PUID=1000
PGID=1000

# Web materials viewer — per-stack host port (each stack picks a unique port).
# Current allocation starts at 8090 and increments per stack.
FINDAJOB_MATERIALS_PORT=8090

# Externally-reachable URL of THIS stack's web UI. Used for ntfy
# click-through links (e.g., the weekly feedback-review push) — those
# render outside the FastAPI app and need an absolute URL. In-app
# materials links are same-origin relative.
#
# Single-tenant LAN-only deploys: set to http://<host>:<port> matching
# this stack's host + FINDAJOB_MATERIALS_PORT. Internet-exposed deploys:
# set to https://<your-subdomain>.<your-domain> (the URL the user types
# into their browser to reach this stack).
#
# Unset → falls back to <deployment-host>:<port> in notify.py.
# Internet-exposed instances MUST set this — testers clicking a weekly
# ntfy feedback-review notification from outside the operator's LAN
# otherwise hit dead URLs.
FINDAJOB_WEB_URL=https://findajob-handle.example.com

# Legacy alias — kept for backward compat; some web routes still read this.
# New stacks: set FINDAJOB_WEB_URL only. (Reading the same value from
# both is fine.)
FINDAJOB_MATERIALS_BASE_URL=https://findajob-handle.example.com

# Triage timeout in seconds. Default 7200 (2h) is generous for steady
# state (~30-45min typical). For fresh installs with a large first feed
# pull, bump to 21600 (6h) for the first week, then drop back.
FINDAJOB_TRIAGE_TIMEOUT=7200

# ── Per-job schedule overrides (#344) ──────────────────────────────────────
# The image's default supercronic schedules live in ops/scheduled-jobs.yaml
# (baked in). Override per-stack with env vars below to stagger same-TZ
# stacks on a multi-tenant host.
#
# Convention: FINDAJOB_<JOB>_SCHEDULE replaces the cron expression;
#             FINDAJOB_<JOB>_ENABLED ("true"/"false") drops the job.
# <JOB> = upper-cased YAML key with `-` → `_` (e.g. notify-apply →
# NOTIFY_APPLY).
#
# All schedules evaluate against the container's TZ env (FINDAJOB_TZ above).
#
# Example: shift triage by 30 min on a second same-TZ stack so two stacks
# don't fire RapidAPI / OpenRouter at the same instant.
# FINDAJOB_TRIAGE_SCHEDULE=30 0 * * *
#
# To inspect the rendered crontab in a running container:
#   docker exec <container> cat /app/crontab
