# ops/compose.yaml.example
# Copy to your Dockge stack directory (e.g., /opt/stacks/findajob-<user>/compose.yaml)
# and edit the adjacent .env to match your instance.
#
# See docs/setup/install-docker.md and ops/stack.env.example for setup.

services:
  scheduler:
    image: ghcr.io/brockamer/findajob:${FINDAJOB_IMAGE_TAG:-v0.1}
    restart: unless-stopped
    ports:
      - "${FINDAJOB_MATERIALS_PORT:-8090}:8090"
    env_file: ./state/data/.env
    environment:
      TZ: ${FINDAJOB_TZ:-America/New_York}
      PUID: ${PUID:-1000}
      PGID: ${PGID:-1000}
      HOME: /app
      JSP_BASE: /app
      FINDAJOB_TRIAGE_TIMEOUT: ${FINDAJOB_TRIAGE_TIMEOUT:-7200}
      FINDAJOB_WEB_URL: ${FINDAJOB_WEB_URL:-}
      FINDAJOB_MATERIALS_BASE_URL: ${FINDAJOB_MATERIALS_BASE_URL:-}
      # Per-job schedule + enabled overrides (#344) — empty default means "use
      # YAML default." Set per-stack in .env to stagger same-TZ multi-tenant
      # hosts. See docs/setup/install-docker.md "Multi-tenant hosts" section.
      FINDAJOB_TRIAGE_SCHEDULE: ${FINDAJOB_TRIAGE_SCHEDULE:-}
      FINDAJOB_TRIAGE_ENABLED: ${FINDAJOB_TRIAGE_ENABLED:-}
      FINDAJOB_WATCHDOG_SCHEDULE: ${FINDAJOB_WATCHDOG_SCHEDULE:-}
      FINDAJOB_WATCHDOG_ENABLED: ${FINDAJOB_WATCHDOG_ENABLED:-}
      FINDAJOB_NOTIFY_APPLY_SCHEDULE: ${FINDAJOB_NOTIFY_APPLY_SCHEDULE:-}
      FINDAJOB_NOTIFY_APPLY_ENABLED: ${FINDAJOB_NOTIFY_APPLY_ENABLED:-}
      FINDAJOB_NOTIFY_STATS_SCHEDULE: ${FINDAJOB_NOTIFY_STATS_SCHEDULE:-}
      FINDAJOB_NOTIFY_STATS_ENABLED: ${FINDAJOB_NOTIFY_STATS_ENABLED:-}
      FINDAJOB_NOTIFY_HEALTH_SCHEDULE: ${FINDAJOB_NOTIFY_HEALTH_SCHEDULE:-}
      FINDAJOB_NOTIFY_HEALTH_ENABLED: ${FINDAJOB_NOTIFY_HEALTH_ENABLED:-}
      FINDAJOB_NOTIFY_ISSUES_SCHEDULE: ${FINDAJOB_NOTIFY_ISSUES_SCHEDULE:-}
      FINDAJOB_NOTIFY_ISSUES_ENABLED: ${FINDAJOB_NOTIFY_ISSUES_ENABLED:-}
      FINDAJOB_NOTIFY_SCOREBOARD_SCHEDULE: ${FINDAJOB_NOTIFY_SCOREBOARD_SCHEDULE:-}
      FINDAJOB_NOTIFY_SCOREBOARD_ENABLED: ${FINDAJOB_NOTIFY_SCOREBOARD_ENABLED:-}
      FINDAJOB_NOTIFY_FEEDBACK_SCHEDULE: ${FINDAJOB_NOTIFY_FEEDBACK_SCHEDULE:-}
      FINDAJOB_NOTIFY_FEEDBACK_ENABLED: ${FINDAJOB_NOTIFY_FEEDBACK_ENABLED:-}
      FINDAJOB_DISCOVER_SCHEDULE: ${FINDAJOB_DISCOVER_SCHEDULE:-}
      FINDAJOB_DISCOVER_ENABLED: ${FINDAJOB_DISCOVER_ENABLED:-}
      FINDAJOB_RAG_REBUILD_SCHEDULE: ${FINDAJOB_RAG_REBUILD_SCHEDULE:-}
      FINDAJOB_RAG_REBUILD_ENABLED: ${FINDAJOB_RAG_REBUILD_ENABLED:-}
    volumes:
      - ./state/data:/app/data
      - ./state/config:/app/config
      - ./state/candidate_context:/app/candidate_context
      - ./state/companies:/app/companies
      - ./state/logs:/app/logs
      - ./state/aichat_ng:/app/.config/aichat_ng
    networks:
      - findajob-network

  gmail-auth:
    image: ghcr.io/brockamer/findajob:${FINDAJOB_IMAGE_TAG:-v0.1}
    profiles: [setup]
    env_file: ./state/data/.env
    environment:
      TZ: ${FINDAJOB_TZ:-America/New_York}
      PUID: ${PUID:-1000}
      PGID: ${PGID:-1000}
      HOME: /app
      JSP_BASE: /app
    volumes:
      - ./state/config:/app/config
    command: python3 scripts/gmail_auth.py
    networks:
      - findajob-network

networks:
  findajob-network:
    driver: bridge
